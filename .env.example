# ============================================
# Argus Central Hub - 环境变量示例文件
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. .env 文件已在 .gitignore 中，不会被提交到 Git
#

# ============================================
# 服务配置
# ============================================
SERVER_PORT=8080

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=argus_central_hub
DB_USERNAME=root
DB_PASSWORD=your_database_password

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================
# 第三方云厂商配置（示例）
# ============================================
# 注意：这些是敏感信息，请勿提交到 Git 仓库

# 自定义云厂商配置示例
THIRD_PARTY_CLOUD_CODE=CUSTOM_CLOUD
THIRD_PARTY_CLOUD_LABEL=自定义云厂商
THIRD_PARTY_CLOUD_API_ENDPOINT=https://api.custom-cloud.com
THIRD_PARTY_CLOUD_AUTH_TYPE=API_KEY
THIRD_PARTY_CLOUD_ACCESS_KEY=your_access_key_here
THIRD_PARTY_CLOUD_SECRET_KEY=your_secret_key_here
THIRD_PARTY_CLOUD_REGION=cn-east-1
